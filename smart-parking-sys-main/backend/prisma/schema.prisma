generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SECURITY
  FACULTY
  STAFF
  STUDENT
  VISITOR
}

enum VehicleType {
  CAR
  BIKE
  TRUCK
  SUV
  VAN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
  WAITLISTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  UPI
  WALLET
  NET_BANKING
  CASH
}

enum ViolationType {
  OVERSTAY
  WRONG_ZONE
  UNAUTHORIZED
  NO_BOOKING
  EXPIRED_PASS
  DOUBLE_PARKING
}

enum ViolationStatus {
  OPEN
  FINE_ISSUED
  PAID
  DISPUTED
  RESOLVED
}

enum PassType {
  MONTHLY
  QUARTERLY
  SEMESTER
  ANNUAL
}

enum SlotType {
  REGULAR
  HANDICAPPED
  EV_CHARGING
  RESERVED_FACULTY
  COMPACT
  LARGE
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  phone           String?
  role            Role      @default(STUDENT)
  rfidTag         String?   @unique @map("rfid_tag")
  department      String?
  employeeId      String?   @unique @map("employee_id")
  isVerified      Boolean   @default(false) @map("is_verified")
  isActive        Boolean   @default(true) @map("is_active")
  verificationToken String? @map("verification_token")
  resetToken      String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  refreshToken    String?   @map("refresh_token")
  avatarUrl       String?   @map("avatar_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  vehicles    Vehicle[]
  bookings    Booking[]
  violations  Violation[]
  payments    Payment[]
  passes      Pass[]
  notifications Notification[]

  @@map("users")
}

model Vehicle {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  licensePlate  String      @unique @map("license_plate")
  vehicleType   VehicleType @map("vehicle_type")
  make          String?
  model         String?
  color         String?
  rfidSticker   String?     @unique @map("rfid_sticker")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  entryLogs  EntryLog[]
  violations Violation[]

  @@map("vehicles")
}

model ParkingZone {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  totalSlots  Int      @map("total_slots")
  hourlyRate  Float    @map("hourly_rate")
  dailyRate   Float?   @map("daily_rate")
  monthlyRate Float?   @map("monthly_rate")
  rules       String?
  latitude    Float?
  longitude   Float?
  color       String   @default("#3B82F6")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  slots ParkingSlot[]

  @@map("parking_zones")
}

model ParkingSlot {
  id         String   @id @default(uuid())
  zoneId     String   @map("zone_id")
  slotNumber String   @map("slot_number")
  slotType   SlotType @default(REGULAR) @map("slot_type")
  floor      Int      @default(1)
  isOccupied Boolean  @default(false) @map("is_occupied")
  isReserved Boolean  @default(false) @map("is_reserved")
  isActive   Boolean  @default(true) @map("is_active")
  posX       Float?   @map("pos_x")
  posY       Float?   @map("pos_y")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  zone     ParkingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([zoneId, slotNumber])
  @@map("parking_slots")
}

model Booking {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  slotId      String        @map("slot_id")
  vehicleId   String        @map("vehicle_id")
  startTime   DateTime      @map("start_time")
  endTime     DateTime      @map("end_time")
  status      BookingStatus @default(PENDING)
  qrCode      String?       @db.Text @map("qr_code")
  totalAmount Float         @map("total_amount")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      ParkingSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  entryLogs EntryLog[]
  payments  Payment[]

  @@map("bookings")
}

model EntryLog {
  id                   String   @id @default(uuid())
  bookingId            String   @map("booking_id")
  vehicleId            String   @map("vehicle_id")
  entryTime            DateTime @default(now()) @map("entry_time")
  entryGate            String?  @map("entry_gate")
  entryPhoto           String?  @map("entry_photo")
  licensePlateCaptured String?  @map("license_plate_captured")
  verificationMethod   String?  @map("verification_method")
  createdAt            DateTime @default(now()) @map("created_at")

  booking  Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  exitLog  ExitLog?

  @@map("entry_logs")
}

model ExitLog {
  id            String        @id @default(uuid())
  entryLogId    String        @unique @map("entry_log_id")
  exitTime      DateTime      @default(now()) @map("exit_time")
  exitGate      String?       @map("exit_gate")
  duration      Int
  amountPaid    Float         @map("amount_paid")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")

  entryLog EntryLog @relation(fields: [entryLogId], references: [id], onDelete: Cascade)

  @@map("exit_logs")
}

model Violation {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  vehicleId   String          @map("vehicle_id")
  type        ViolationType
  description String?
  fineAmount  Float           @map("fine_amount")
  status      ViolationStatus @default(OPEN)
  evidence    String?
  resolvedAt  DateTime?       @map("resolved_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("violations")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String?       @map("booking_id")
  userId        String        @map("user_id")
  amount        Float
  method        PaymentMethod @default(UPI)
  transactionId String?       @unique @map("transaction_id")
  status        PaymentStatus @default(PENDING)
  description   String?
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Pass {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  passType  PassType @map("pass_type")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  price     Float
  isActive  Boolean  @default(true) @map("is_active")
  zoneId    String?  @map("zone_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passes")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
